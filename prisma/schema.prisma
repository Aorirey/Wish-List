// Prisma schema for Wishlist MVP.
// По умолчанию используется SQLite для быстрого старта. Для продакшена
// замените `provider` на `postgresql` и восстановите enum'ы
// `Visibility` / `ItemStatus` (SQLite не поддерживает enum'ы).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Допустимые значения Visibility: "PUBLIC" | "LINK" | "PRIVATE"
// Допустимые значения ItemStatus: "AVAILABLE" | "AWAITING" | "RESERVED"

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  username      String        @unique
  name          String?
  avatarUrl     String?
  createdAt     DateTime      @default(now())
  wishlists     Wishlist[]    @relation("UserWishlists")
  following     Follow[]      @relation("Follower")
  followers     Follow[]      @relation("Following")
  reservations  Reservation[]
}

model Follow {
  id          String   @id @default(cuid())
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followerId  String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Wishlist {
  id          String   @id @default(cuid())
  title       String
  description String?
  visibility  String   @default("PUBLIC")
  coverUrl    String?
  owner       User     @relation("UserWishlists", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String
  items       Item[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Item {
  id           String        @id @default(cuid())
  wishlist     Wishlist      @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  wishlistId   String
  title        String
  description  String?
  category     String
  url          String?
  price        Int
  currency     String        @default("RUB")
  store        String?
  imageUrl     String?
  status       String        @default("AVAILABLE")
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Reservation {
  id        String   @id @default(cuid())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  note      String?
  createdAt DateTime @default(now())

  @@unique([itemId, userId])
}
